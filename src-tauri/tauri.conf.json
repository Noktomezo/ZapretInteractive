{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zapret Interactive",
  "version": "1.4.1",
  "identifier": "com.noktomezo.zapret-interactive",
  "mainBinaryName": "Zapret Interactive",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zapret Interactive",
        "width": 900,
        "height": 700,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "publisher": "Noktomezo",
    "shortDescription": "GUI for zapret-win-bundle",
    "longDescription": "Desktop GUI for managing zapret strategies, filters, placeholders, file recovery and updates.",
    "copyright": "Copyright © 2026 Noktomezo",
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "resources": {
      "../thirdparty/WinDivert.dll": "resources/WinDivert.dll",
      "../thirdparty/Monkey64.sys": "resources/Monkey64.sys",
      "../thirdparty/winws.exe": "resources/winws.exe",
      "../thirdparty/cygwin1.dll": "resources/cygwin1.dll",
      "../thirdparty/hashes.json": "resources/hashes.json",
      "../thirdparty/modules/": "resources/modules/",
      "../thirdparty/fake/": "resources/fake/",
      "../thirdparty/lists/": "resources/lists/"
    },
    "windows": {
      "nsis": {
        "installerIcon": "../assets/app-logo.ico",
        "headerImage": "../assets/app-installer-header.bmp",
        "sidebarImage": "../assets/app-installer-sidebar.bmp"
      }
    },
    "icon": [
      "icons/100x100.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2MUI5OTIzNDcyM0RFNDYKUldSRzNpTkhJNWtiTm5XRFhtOWtLR2ZtQjlNc1RKb05sMjRTOWRiTU0zRjhiWE1xNXFrakJoaUoK",
      "endpoints": [
        "https://github.com/Noktomezo/ZapretInteractive/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
