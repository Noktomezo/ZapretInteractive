{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zapret Interactive",
  "version": "1.0.6",
  "identifier": "com.noktomezo.zapret-interactive",
  "mainBinaryName": "Zapret Interactive",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zapret Interactive",
        "width": 900,
        "height": 700,
        "center": true,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "publisher": "Noktomezo",
    "active": true,
    "targets": "nsis",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/100x100.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI0Njk1ODkwNjJBNkIyRjgKUldUNHNxWmlrRmhwdEk2Nk5GRHl3ajN6SGxPaGhhUmxyV2xwc05zTjR6TlQ3TjZDZThSc2NrMjQK",
      "endpoints": [
        "https://github.com/Noktomezo/ZapretInteractive/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
